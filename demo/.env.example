# 主服务器配置
# HTTP 服务器端口（默认：3000）
APP_PORT=3000

# WebSocket 路径（默认：/ws）
WS_PATH=/ws

# 邻近服务配置
# 通话半径，方块距离（默认：10）
CALL_RADIUS=10

# 邻近检测间隔，毫秒（默认：250）
PROXIMITY_TICK_MS=250

# 玩家数据过期时间，毫秒（默认：10000）
GAME_PLAYER_TTL_MS=10000

# 重连验证码有效期，毫秒（默认：120000）
RECONNECT_CODE_TTL_MS=120000

# Minecraft 网关认证令牌（必须与网关配置一致）
MCBEWEBRTC_TOKEN=

# 调试模式（true/false，默认：false）
DEBUG=false

# WebRTC ICE 服务器配置
# 方式1：使用 JSON 格式（优先级更高）
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]

# 方式2：使用单独的环境变量
# STUN 服务器 URL 列表，逗号分隔
STUN_URLS=stun:stun.l.google.com:19302

# TURN 服务器配置
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# 网关配置
# 网关监听端口（默认：8000）
GATEWAY_PORT=8000

# 主服务器 WebSocket URL
SIGNALING_URL=ws://localhost:3000/ws
