# ============ 后端连接配置 ============
# Backend 服务地址（不含末尾斜杠）
BACKEND_URL=http://127.0.0.1:3000

# ============ 桥接鉴权配置 ============
# 必须与 backend 的 BRIDGE_JWT_SECRET 一致
# 生产环境必须使用强随机字符串，长度至少 16 字符
BRIDGE_JWT_SECRET=your-secure-random-secret-here
# JWT 过期时间
JWT_EXPIRES_IN=2h

# ============ MC 网关配置 ============
# Minecraft WebSocket 服务器监听端口
GATEWAY_PORT=8000
# 调试模式开关
DEBUG=false
