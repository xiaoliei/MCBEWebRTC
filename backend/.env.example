# ============ 服务配置 ============
# 服务端口
PORT=3000
# 服务监听地址
HOST=0.0.0.0

# ============ 桥接鉴权配置 ============
# mcwss 与 backend 之间的 JWT 密钥，必须与 mcwss 一致
# 生产环境必须使用强随机字符串，长度至少 16 字符
BRIDGE_JWT_SECRET=your-secure-random-secret-here
# 桥接 JWT 过期时间
JWT_EXPIRES_IN=2h

# ============ 玩家 Token 配置 ============
# 玩家 JWT 密钥，用于玩家会话鉴权
PLAYER_JWT_SECRET=your-player-jwt-secret-here
# 玩家 JWT 过期时间
PLAYER_JWT_EXPIRES_IN=24h
# 玩家 Token 刷新策略（当前仅支持 none）
PLAYER_TOKEN_REFRESH_STRATEGY=none

# ============ ICE 服务器配置 ============
# WebRTC STUN/TURN 服务器配置，JSON 数组格式
# 示例: [{"urls":"stun:stun.l.google.com:19302"}]
ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# ============ 验证功能开关 ============
# 是否启用验证功能
AUTH_VERIFICATION_ENABLED=true

# ============ /tell 验证码配置 ============
AUTH_TELL_ENABLED=true
# 验证码有效期（毫秒）
AUTH_TELL_CODE_TTL_MS=120000
# 验证码请求频率限制时间窗口（毫秒）
AUTH_TELL_RATE_LIMIT_WINDOW_MS=60000
# 验证码请求频率限制最大次数
AUTH_TELL_RATE_LIMIT_MAX=3

# ============ manual 手动验证配置 ============
AUTH_MANUAL_ENABLED=true
# 手动验证 challenge 有效期（毫秒）
AUTH_MANUAL_CODE_TTL_MS=300000
# 手动验证请求频率限制时间窗口（毫秒）
AUTH_MANUAL_RATE_LIMIT_WINDOW_MS=60000
# 手动验证请求频率限制最大次数
AUTH_MANUAL_RATE_LIMIT_MAX=3
# 手动验证消息前缀
AUTH_MANUAL_MESSAGE_PREFIX=#

# ============ 清理任务配置 ============
# Token 白名单清理间隔（毫秒）
AUTH_TOKEN_CLEANUP_INTERVAL_MS=60000
# 验证会话清理间隔（毫秒）
AUTH_VERIFY_SESSION_CLEANUP_INTERVAL_MS=60000

# proximity call radius (in blocks)
CALL_RADIUS=16
